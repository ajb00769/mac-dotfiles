// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-thinking-latest",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "relative_line_numbers": "enabled",
  "theme": "One Dark Pro Glass",
  "buffer_font_family": "Liga Comic Mono",
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_size": 13,
  "buffer_font_features": {
    "calt": true,
  },
  "format_on_save": "on",
  "edit_predictions": {
    "provider": "none",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "project_panel": {
    "entry_spacing": "standard",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  // language settings
  "languages": {
    "Python": {
      "language_servers": ["pyright"],
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "-"],
        },
      },
    },

    "TypeScript": {
      "language_servers": ["typescript-language-server", "eslint"],
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },

    "JavaScript": {
      "language_servers": ["typescript-language-server", "eslint"],
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },

    "Go": {
      "language_servers": ["gopls"],
    },
  },

  "lsp": {
    "ruff": {
      "settings": {
        "python.pythonPath": "~/.pyenv/shims/python",
        "python.analysis.typeCheckingMode": "basic",
      },
    },

    "gopls": {
      "settings": {
        "staticcheck": true,
        "gofumpt": true,
      },
    },

    "eslint": {
      "settings": {
        "workingDirectory": { "mode": "auto" },
      },
    },
  },
}
